# Copy to `.env` (Expo loads EXPO_PUBLIC_* at bundle time).
# Endpoint must include `/v1` — for Appwrite Cloud use your region URL from the console.
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=69f68ebd0038c90bce46

# Optional: override platform header if it must match a fixed package/bundle ID from Appwrite Auth → Platforms.
# EXPO_PUBLIC_APPWRITE_PLATFORM=com.yourcompany.relestate
